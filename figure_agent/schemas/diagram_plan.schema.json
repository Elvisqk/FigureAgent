{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "diagram_plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "figure_id", "diagram_type", "layout_mode", "nodes", "edges", "clusters", "lanes", "primary_flow", "routing_hints", "label_policy"],
  "properties": {
    "request_id": {"type": "string", "minLength": 1},
    "figure_id": {"type": "string", "minLength": 1},
    "diagram_type": {"type": "string", "enum": ["pipeline", "module_architecture", "agent_workflow", "decision_flow"]},
    "layout_mode": {
      "type": "string",
      "enum": ["layered_lr", "layered_tb", "grid", "hub_spoke", "swimlane_lr", "swimlane_tb", "branch_merge"]
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "role", "group"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "role": {"type": "string"},
          "group": {"type": ["string", "null"]}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "target", "kind"],
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "kind": {"type": "string", "enum": ["primary", "secondary", "feedback"]},
          "label": {"type": ["string", "null"]}
        }
      }
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cluster_id", "label", "role", "members"],
        "properties": {
          "cluster_id": {"type": "string"},
          "label": {"type": "string"},
          "role": {"type": "string"},
          "members": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lane_id", "label", "role", "members"],
        "properties": {
          "lane_id": {"type": "string"},
          "label": {"type": "string"},
          "role": {"type": "string"},
          "members": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "primary_flow": {
      "type": "array",
      "items": {"type": "string"}
    },
    "routing_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prefer_orthogonal_edges", "separate_primary_and_secondary_edges"],
      "properties": {
        "prefer_orthogonal_edges": {"type": "boolean"},
        "separate_primary_and_secondary_edges": {"type": "boolean"}
      }
    },
    "label_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_chars_per_line", "max_lines_per_node"],
      "properties": {
        "max_chars_per_line": {"type": "integer", "minimum": 8, "maximum": 40},
        "max_lines_per_node": {"type": "integer", "minimum": 1, "maximum": 5}
      }
    }
  }
}
