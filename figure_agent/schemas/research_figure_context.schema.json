{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research_figure_context.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": ["paper_id", "paper_title", "target_stage", "section_plan", "analysis_claims", "method_summaries", "evidence_catalog", "style_profile", "output_formats", "max_revision_rounds"],
  "properties": {
    "paper_id": {"type": "string", "minLength": 1},
    "paper_title": {"type": "string", "minLength": 1},
    "target_stage": {"type": "string", "minLength": 1},
    "section_plan": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "analysis_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["claim_id", "text", "target_section"],
        "properties": {
          "claim_id": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "target_section": {"type": "string", "minLength": 1},
          "importance": {"type": "string", "enum": ["high", "medium", "low"]},
          "suggested_figure_kind": {"type": "string", "enum": ["chart", "diagram"]},
          "suggested_chart_type": {"type": "string"},
          "evidence_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "method_summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["summary_id", "text", "target_section"],
        "properties": {
          "summary_id": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "target_section": {"type": "string", "minLength": 1},
          "importance": {"type": "string", "enum": ["high", "medium", "low"]},
          "suggested_diagram_type": {"type": "string"},
          "evidence_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "evidence_catalog": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["evidence_id", "kind"],
        "properties": {
          "evidence_id": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "enum": ["table_file", "json_file", "text_block", "section_excerpt"]},
          "path": {"type": ["string", "null"]},
          "content": {"type": ["string", "null"]},
          "columns": {"type": "array", "items": {"type": "string"}},
          "row_count": {"type": ["integer", "null"]},
          "sheet": {"type": ["string", "null"]},
          "table_name": {"type": ["string", "null"]},
          "row_selector": {"type": ["object", "array", "string", "null"]},
          "column_selector": {"type": ["object", "array", "string", "null"]},
          "paragraph_ref": {"type": ["string", "null"]},
          "sha256": {"type": ["string", "null"]}
        }
      }
    },
    "style_profile": {"type": "string"},
    "output_formats": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "enum": ["png", "pdf", "svg"]},
      "uniqueItems": true
    },
    "max_revision_rounds": {"type": "integer", "minimum": 0, "maximum": 2}
  }
}
